# Spotify Web API — Authorization Code flow (one-time user login).
# Used by /api/spotify/playlist to fetch the curated playlist on /creative.
#
# Setup:
#   1. https://developer.spotify.com/dashboard → log in → Create app
#   2. Settings → copy Client ID + (View) Client Secret
#   3. Add redirect URI: http://localhost:3000/api/auth/spotify/callback
#   4. Copy the playlist ID from share URL: open.spotify.com/playlist/<ID>?si=...
#   5. Fill the first three vars below, restart dev server
#   6. Visit http://localhost:3000/api/auth/spotify/login → authorize
#   7. Callback page shows the refresh token — paste below as SPOTIFY_REFRESH_TOKEN
#   8. Restart dev server

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_PLAYLIST_ID=
SPOTIFY_REFRESH_TOKEN=
